{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
  "baseUrl": ".",
  "paths": {
      "@/lib/*": [
        "src/lib/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
  "src/types/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts", // keep for editor features; excluded from build typecheck below
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts/**" // exclude scripts from Next build typecheck
  ]
}
